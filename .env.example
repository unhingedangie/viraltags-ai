# ViralTags AI — Environment Variables
# Copy this file to .env.local and fill in your keys

# ======================
# ANTHROPIC (AI Engine)
# ======================
# Sign up at https://console.anthropic.com
# The AI features use Claude with web search for real-time hashtag research
ANTHROPIC_API_KEY=

# ======================
# SUPABASE (Auth + Database)
# ======================
# Sign up at https://supabase.com — free tier is plenty
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ======================
# STRIPE (Payments)
# ======================
# Sign up at https://stripe.com
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ======================
# APP CONFIG
# ======================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to force demo mode even when API keys are present
NEXT_PUBLIC_DEMO_MODE=true
